name: Selenium Tests CI

on:
  push:
    branches: [ "main" ]

jobs:
  test:
    runs-on: ubuntu-latest

    steps:
    - name: Checkout code
      uses: actions/checkout@v3

    - name: Setup Python
      uses: actions/setup-python@v4
      with:
        python-version: "3.10"

    - name: Debug files
      run: |
        pwd
        ls -la

    - name: Install dependencies
      run: pip install -r requirements.txt

    - name: Run Tests
      run: pytest -v
